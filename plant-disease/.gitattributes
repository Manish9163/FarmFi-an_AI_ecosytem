# Auto detect text files and normalize line endings to LF in repository
* text=auto

# Python files
*.py text eol=lf
*.pyw text eol=lf

# Jupyter notebooks
*.ipynb text eol=lf

# Web files
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf
*.json text eol=lf

# Configuration files
*.yml text eol=lf
*.yaml text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.ini text eol=lf
*.cfg text eol=lf

# Shell scripts
*.sh text eol=lf

# Windows scripts
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.keras binary
*.h5 binary
*.pkl binary
*.npy binary
*.npz binary
